# ---------------------------------------------------------------------------
# Greenery API — Example environment file
# Copy to .env and fill in real values. Never commit .env to git.
# ---------------------------------------------------------------------------

# Server
PORT=3001
NODE_ENV=development

# Database (local Docker by default — see apps/api/db/docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=greenery
DB_USER=greenery_user
DB_PASSWORD=your_db_password_here

# CORS allowlist (comma-separated origins; no wildcards)
CORS_ORIGINS=http://localhost:3000,http://localhost:8082

# Authentication
AUTH_PROVIDER=firebase

# Firebase Admin SDK (server-side credentials — never expose to clients)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXXX@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-private-key-here>\n-----END PRIVATE KEY-----\n"

# Rate limiting (defaults shown — override in .env if needed)
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=30

# Monday.com integration (optional — leave blank OR delete these lines entirely
# to run without sync. env.js normalizes empty strings to undefined so a blank
# value behaves identically to an absent line.)
#
# MONDAY_API_TOKEN      — personal API token, Monday Developer Center → API token
# MONDAY_BOARD_ID       — numeric ID from the board URL
# MONDAY_WEBHOOK_SECRET — used in the inbound webhook URL path, ≥32 chars.
#                         Generate with: openssl rand -hex 32
#                         NOTE: A non-empty value shorter than 32 chars will
#                         crash boot. Blank is fine; short is not.
# MONDAY_API_VERSION    — pinned API version for stability (default 2024-10)
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_WEBHOOK_SECRET=
MONDAY_API_VERSION=2024-10
